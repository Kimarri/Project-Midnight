# ─── Stripe ────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_ for testing, sk_live_ for production
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE

# Get this from https://dashboard.stripe.com/webhooks
# Create a webhook endpoint pointing to your Cloud Function URL:
# https://us-central1-YOUR_PROJECT.cloudfunctions.net/stripeWebhook
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Email (Resend) ───────────────────────────────────
# Sign up at https://resend.com and create an API key
# Free tier: 100 emails/day
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
