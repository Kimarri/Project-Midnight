rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth() && request.auth.token.email == 'getnoteflowapp@gmail.com';
    }
    // Limit document size to prevent abuse (100KB)
    function isReasonableSize() {
      return request.resource.data.keys().size() < 50;
    }

    // ─── Users Collection ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);

      // Create: must include email, no spoofing other fields
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && isReasonableSize();

      // Update: can't change their own subscription status or plan
      // (only backend/admin can do that via Admin SDK)
      allow update: if isOwner(userId)
        && isReasonableSize()
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['subscriptionStatus', 'plan', 'stripeCustomerId', 'stripeSessionId'])
            || isAdmin());

      allow delete: if false; // Only backend can delete (GDPR endpoint)

      // Projects subcollection
      match /projects/{projectId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['name'])
          && request.resource.data.name is string;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ─── Email Queue ──────────────────────────────────────────────────
    // Only auth users can create; `from` must match their own email to prevent spoofing
    match /emailQueue/{emailId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['to', 'subject', 'eventType', 'from'])
        && request.resource.data.to is string
        && request.resource.data.subject is string
        && request.resource.data.from == request.auth.token.email
        && request.resource.data.to.size() > 0
        && request.resource.data.to.size() < 320
        && request.resource.data.subject.size() < 200
        && request.resource.data.eventType in ['assigned', 'in-review', 'manager-approved', 'partner-approved', 'returned', 'comment'];
      allow read, update, delete: if false;
    }

    // ─── Error Logs ───────────────────────────────────────────────────
    match /errorLogs/{logId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['timestamp', 'message'])
        && request.resource.data.message is string
        && request.resource.data.message.size() < 1000;
      allow read, update, delete: if false;
    }

    // ─── Analytics ────────────────────────────────────────────────────
    // Only allow incrementing known counter fields; dateId must be a valid YYYY-MM-DD format
    match /analytics/{dateId} {
      allow create, update: if isAuth()
        && dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.keys().hasOnly([
          'logins', 'statements_generated', 'pdf_exports',
          'excel_exports', 'projects_created', 'lastActivity'
        ])
        && (request.resource.data.logins is int || !('logins' in request.resource.data))
        && (request.resource.data.statements_generated is int || !('statements_generated' in request.resource.data))
        && (request.resource.data.pdf_exports is int || !('pdf_exports' in request.resource.data))
        && (request.resource.data.excel_exports is int || !('excel_exports' in request.resource.data))
        && (request.resource.data.projects_created is int || !('projects_created' in request.resource.data));
      allow read: if isAdmin();
      allow delete: if false;
    }

    // ─── Config ───────────────────────────────────────────────────────
    match /config/{configId} {
      allow read: if isAuth() && configId == 'safeMode'
                  || isAdmin(); // Only admin reads all config; users only read Safe Mode
      allow write: if isAdmin();
    }

    // ─── Backend-Only Collections (admin can read) ─────────────────────
    match /healthLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only backend writes
    }
    match /dailyMetrics/{dateId} {
      allow read: if isAdmin();
      allow write: if false; // Only backend writes
    }
    match /processedEvents/{eventId} {
      allow read, write: if false; // Fully backend-only
    }

    // ─── Default Deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
